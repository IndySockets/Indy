<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{EC04471C-07B1-417C-AAB7-9057CDC19654}</ProjectGuid>
        <MainSource>IndyCore110Net.dpk</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <TargetedPlatforms>1</TargetedPlatforms>
        <AppType>Package</AppType>
        <FrameworkType>None</FrameworkType>
        <ProjectVersion>20.2</ProjectVersion>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectName Condition="'$(ProjectName)'==''">IndyCore110Net</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DllSuffix>110Net</DllSuffix>
        <DCC_Description>Indy 10 Core</DCC_Description>
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;Bde;$(DCC_Namespace)</DCC_Namespace>
        <DCC_UnitSearchPath>..\..\Lib\Source\Includes;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <RuntimeOnlyPackage>true</RuntimeOnlyPackage>
        <GenDll>true</GenDll>
        <GenPackage>true</GenPackage>
        <DCC_OutputNeverBuildDcps>true</DCC_OutputNeverBuildDcps>
        <DCC_CBuilderOutput>All</DCC_CBuilderOutput>
        <DCC_ImageBase>00400000</DCC_ImageBase>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_DebugInformation>false</DCC_DebugInformation>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\..\Lib\Source\Core\IdAssignedNumbers.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdBuffer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdCmdTCPClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdCmdTCPServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdCommandHandlers.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdContext.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdCustomTCPServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdCustomTransparentProxy.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdExceptionCore.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdGlobalCore.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIOHandler.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIOHandlerSocket.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIOHandlerStack.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIOHandlerStream.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIPAddress.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIPMCastBase.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIPMCastClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIPMCastServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIcmpClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdIntercept.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdInterceptSimLog.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdInterceptThrottler.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdLogBase.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdLogDebug.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdLogEvent.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdLogFile.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdLogStream.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdRawBase.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdRawClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdRawFunctions.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdRawHeaders.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdReply.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdReplyRFC.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdResourceStringsCore.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdScheduler.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSchedulerOfThread.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSchedulerOfThreadDefault.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSchedulerOfThreadPool.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdServerIOHandler.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdServerIOHandlerSocket.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdServerIOHandlerStack.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSimpleServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSocketHandle.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSocks.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdSync.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTCPClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTCPConnection.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTCPServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTCPStream.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTask.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdThread.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdThreadComponent.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdThreadSafe.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdTraceRoute.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdUDPBase.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdUDPClient.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdUDPServer.pas"/>
        <DCCReference Include="..\..\Lib\Source\Core\IdYarn.pas"/>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Package</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">IndyCore110Net.dpk</Source>
                </Source>
                <Platforms>
                    <Platform value="Win32">True</Platform>
                </Platforms>
            </Delphi.Personality>
        </BorlandProject>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
