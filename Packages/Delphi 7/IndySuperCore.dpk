package IndySuperCore;

{$R *.res}
{$BOOLEVAL OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION ON}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES OFF}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DESCRIPTION 'Indy 10 SuperCore'}
{$RUNONLY}
{$IMPLICITBUILD OFF}
{$LIBSUFFIX '70'}

requires
  rtl,
  IndySystem,
  IndyCore;

contains
  IdFiber in '..\..\Lib\Source\SuperCore\IdFiber.pas',
  IdFiberWeaver in '..\..\Lib\Source\SuperCore\IdFiberWeaver.pas',
  IdFiberWeaverInline in '..\..\Lib\Source\SuperCore\IdFiberWeaverInline.pas',
  IdFiberWeaverThreaded in '..\..\Lib\Source\SuperCore\IdFiberWeaverThreaded.pas',
  IdIOHandlerChain in '..\..\Lib\Source\SuperCore\IdIOHandlerChain.pas',
  IdSchedulerOfFiber in '..\..\Lib\Source\SuperCore\IdSchedulerOfFiber.pas',
  IdServerIOHandlerChain in '..\..\Lib\Source\SuperCore\IdServerIOHandlerChain.pas',
  IdWorkOpUnit in '..\..\Lib\Source\SuperCore\IdWorkOpUnit.pas',
  IdWorkOpUnits in '..\..\Lib\Source\SuperCore\IdWorkOpUnits.pas';

end.
