<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{168608C4-572C-4A59-BDC9-217C6E49D16A}</ProjectGuid>
        <MainSource>IndySystem.dpk</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Package</AppType>
        <FrameworkType>None</FrameworkType>
        <ProjectVersion>19.1</ProjectVersion>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectName Condition="'$(ProjectName)'==''">IndySystem</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DllSuffix>270</DllSuffix>
        <DCC_Description>Indy 10 System</DCC_Description>
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;Bde;$(DCC_Namespace)</DCC_Namespace>
        <DCC_UnitSearchPath>..\..\Source\Includes;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <RuntimeOnlyPackage>true</RuntimeOnlyPackage>
        <GenDll>true</GenDll>
        <GenPackage>true</GenPackage>
        <DCC_OutputNeverBuildDcps>true</DCC_OutputNeverBuildDcps>
        <DCC_CBuilderOutput>All</DCC_CBuilderOutput>
        <DCC_ImageBase>00400000</DCC_ImageBase>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="rtl.dcp"/>
        <DCCReference Include="..\..\Source\System\IdAntiFreezeBase.pas"/>
        <DCCReference Include="..\..\Source\System\IdBaseComponent.pas"/>
        <DCCReference Include="..\..\Source\System\IdCTypes.pas"/>
        <DCCReference Include="..\..\Source\System\IdComponent.pas"/>
        <DCCReference Include="..\..\Source\System\IdException.pas"/>
        <DCCReference Include="..\..\Source\System\IdGlobal.pas"/>
        <DCCReference Include="..\..\Source\System\IdIDN.pas"/>
        <DCCReference Include="..\..\Source\System\IdResourceStrings.pas"/>
        <DCCReference Include="..\..\Source\System\IdResourceStringsUnix.pas"/>
        <DCCReference Include="..\..\Source\System\IdResourceStringsVCLPosix.pas"/>
        <DCCReference Include="..\..\Source\System\IdStack.pas"/>
        <DCCReference Include="..\..\Source\System\IdStackBSDBase.pas"/>
        <DCCReference Include="..\..\Source\System\IdStackConsts.pas"/>
        <DCCReference Include="..\..\Source\System\IdStackWindows.pas"/>
        <DCCReference Include="..\..\Source\System\IdStackVCLPosix.pas"/>
        <DCCReference Include="..\..\Source\System\IdStream.pas"/>
        <DCCReference Include="..\..\Source\System\IdStreamVCL.pas"/>
        <DCCReference Include="..\..\Source\System\IdStruct.pas"/>
        <DCCReference Include="..\..\Source\System\IdWinsock2.pas"/>
        <DCCReference Include="..\..\Source\System\IdWship6.pas"/>
        <DCCReference Include="..\..\Source\System\IdVCLPosixSupplemental.pas"/>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Package</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">IndySystem.dpk</Source>
                </Source>
                <Platforms>
                    <Platform value="Win32">True</Platform>
                    <Platform value="Win64">True</Platform>
                </Platforms>
            </Delphi.Personality>
        </BorlandProject>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
